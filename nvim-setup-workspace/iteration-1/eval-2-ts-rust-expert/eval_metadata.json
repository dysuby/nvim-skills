{
  "eval_id": 2,
  "eval_name": "ts-rust-expert",
  "prompt": "帮我 setup neovim，我是老手，用过 vim 多年。我主要写 TypeScript 和 Rust，macOS。给我推荐一个现代化的配置。",
  "assertions": [
    {
      "id": "has_ts_ls",
      "description": "lsp.lua contains ts_ls for TypeScript language server",
      "check": "grep 'ts_ls\\|tsserver\\|typescript' outputs/lua/config/plugins/lsp.lua"
    },
    {
      "id": "has_rust_analyzer",
      "description": "lsp.lua contains rust_analyzer for Rust language server",
      "check": "grep 'rust_analyzer' outputs/lua/config/plugins/lsp.lua"
    },
    {
      "id": "has_ts_treesitter",
      "description": "treesitter.lua includes typescript and/or tsx parsers",
      "check": "grep 'typescript\\|tsx' outputs/lua/config/plugins/treesitter.lua"
    },
    {
      "id": "has_rust_treesitter",
      "description": "treesitter.lua includes rust parser",
      "check": "grep '\"rust\"\\|rust' outputs/lua/config/plugins/treesitter.lua"
    },
    {
      "id": "has_tokyonight",
      "description": "colorscheme.lua uses tokyo night theme",
      "check": "grep -i 'tokyonight\\|tokyo' outputs/lua/config/plugins/colorscheme.lua"
    },
    {
      "id": "no_which_key",
      "description": "which-key.lua should NOT exist for expert user",
      "check": "! test -f outputs/lua/config/plugins/which-key.lua"
    },
    {
      "id": "has_noice",
      "description": "noice.lua exists (expert UI upgrade)",
      "check": "test -f outputs/lua/config/plugins/noice.lua"
    },
    {
      "id": "has_fugitive",
      "description": "gitsigns or a plugin file contains fugitive for expert git workflow",
      "check": "grep -r 'fugitive' outputs/lua/config/plugins/"
    }
  ]
}
